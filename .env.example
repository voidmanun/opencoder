# DingTalk App Credentials
# Get these from https://open-dev.dingtalk.com
DINGTALK_CLIENT_ID=your_client_id_here
DINGTALK_CLIENT_SECRET=your_client_secret_here

# OpenCode Server Configuration
# Start the server with: opencode serve
OPENCODE_SERVER_URL=http://127.0.0.1:4096
OPENCODE_SERVER_PASSWORD=your_opencode_password_here
OPENCODE_SERVER_USERNAME=opencode

# Bridge Configuration
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8080
BRIDGE_MODE=advanced
BRIDGE_WORKDIR=.

# Session Configuration
SESSION_STORE_PATH=~/.dingtalk-bridge/sessions.json
SESSION_TIMEOUT=28800

# Security Configuration
DINGTALK_USER_WHITELIST_PATH=./config/user_whitelist.json
TOOL_WHITELIST_PATH=./config/tool_whitelist.json

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=~/.dingtalk-bridge/bridge.log